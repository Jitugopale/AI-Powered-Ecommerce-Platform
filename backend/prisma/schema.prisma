generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Roles{
  USER 
  ADMIN
  SUPER_ADMIN
}

model User{
  id Int @id @default(autoincrement())
  name String
  email String @unique
  mobile_no String
  password String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  role Roles @default(USER)
  adress Address[]

  @@map("users")
}

model Address{
  id Int @id @default(autoincrement())
  userId Int @unique
  addressline String
  state String
  city String
  pincode String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId],references: [id])
  @@map("address")
}

model Categories{
  id Int @id @default(autoincrement())
  name String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("categories")
}